{
    "interval_seconds": 60,

    "api": {
        "base_url": "https://api.coingecko.com/api/v3",
        "timeout": 5,
        "max_retries": 3
    },
    
    "coins": [
        {
            "id": "bitcoin",
            "symbol": "BTC",
            "alerts": [
            {"type": "above", "value": 100000},
            {"type": "below", "value": 60000}
            ]
        },
        {
            "id": "ethereum",
            "symbol": "ETH",
            "alerts": [
            {"type": "above", "value": 3000},
            {"type": "below", "value":2000}
            ]
        },
        {
            "id": "celestia",
            "symbol": "TIA",
            "alerts": [
            {"type": "above", "value": 1},
            {"type": "below", "value": 0.2}
            ]
        },
        {
            "id": "litecoin",
            "symbol": "LTC",
            "alerts": [
            {"type": "above", "value": 70},
            {"type": "below", "value": 50}
            ]
        }
    ],

    "storage": {
        "file_path": "data/prices.json"
    },

    "logging": {
        "level": "INFO",
        "file_path": "logs/app.log"
    }
}